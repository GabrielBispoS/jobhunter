# ─────────────────────────────────────────────────────────
# JobHunter — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o arquivo .env com valores reais
# ─────────────────────────────────────────────────────────

# Servidor
PORT=3001
DB_PATH=./data/jobhunter.db

# CORS: URL do frontend em produção (ex: https://meuapp.railway.app)
# Use * apenas em desenvolvimento local
FRONTEND_URL=https://seu-dominio.com

# Autenticação (ALTAMENTE RECOMENDADO em produção)
# Defina uma senha forte para proteger o acesso à aplicação
AUTH_PASSWORD=sua_senha_segura_aqui
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_um_segredo_aleatorio_longo_aqui

# Playwright
HEADLESS=true
PLAYWRIGHT_CONCURRENCY=3

# Google Gemini — para análise de CV, carta de apresentação, insights de empresa
# Obtenha gratuitamente em: aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_ou_AQ.xxxx

# Email notifications (opcional — para alertas de vagas)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@gmail.com
# SMTP_PASS=sua_senha_de_app
# NOTIFY_EMAIL=seu@gmail.com

# Cron padrão (opcional — configure também pelo dashboard)
# DEFAULT_CRON=0 8 * * 1-5
# DEFAULT_KEYWORDS=desenvolvedor java,spring boot,backend
# DEFAULT_SOURCES=gupy,inhire,geekhunter,remoteok
